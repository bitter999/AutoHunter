# ============================================================================
#  AutoHunter 配置示例  ——  复制为 .env 后按需修改
#  Powered By StanleyNull  
#
#  最少只需填 LLM_API_KEY 即可启动；FOFA_KEY / 访问令牌强烈建议配置。
# ============================================================================

# ---------------------------------------------------------------------------
# 【必填】AI / LLM 通道（OpenAI 兼容接口，Worker/Reviewer/报告助手共用）
# 官方 DeepSeek、通义千问、Kimi、OpenAI、以及任何 OpenAI 兼容网关都可以。
# ---------------------------------------------------------------------------
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# ---------------------------------------------------------------------------
# 【推荐】FOFA 网络空间测绘 Key（用于自动搜集目标资产；不填则只能手动录入目标）
# 到 https://fofa.info 个人中心获取。
# ---------------------------------------------------------------------------
FOFA_KEY=

# 【可选】自定义 FOFA API 端点（对接私有部署/镜像/代理网关时使用）。
# 留空则使用官方 https://fofa.info。
FOFA_BASE_URL=

# ---------------------------------------------------------------------------
# 【强烈建议】访问控制令牌（不设则任何人都能访问你的控制台！）
#   AUTOHUNTER_API_TOKEN      全权限（读写、启停任务、复审）
#   AUTOHUNTER_READ_TOKEN     只读（看板/GET，禁止写操作）—— 可选
#   AUTOHUNTER_OBSERVER_TOKEN 观摩（仅运行概况，无敏感证据）—— 可选
# 请改成足够长的随机串（install.sh 会自动帮你生成）。
# ---------------------------------------------------------------------------
AUTOHUNTER_API_TOKEN=
AUTOHUNTER_READ_TOKEN=
AUTOHUNTER_OBSERVER_TOKEN=

# ---------------------------------------------------------------------------
# 服务监听（容器内）。对外端口在 docker-compose.yml 里映射。
# ---------------------------------------------------------------------------
AUTOHUNTER_HOST=0.0.0.0
AUTOHUNTER_PORT=18800

# ---------------------------------------------------------------------------
# 内置应用层 WAF（保护控制台本身）
# ---------------------------------------------------------------------------
AUTOHUNTER_WAF_ENABLED=1
AUTOHUNTER_WAF_BLOCK=1
AUTOHUNTER_TRUST_PROXY=0
AUTOHUNTER_WAF_MAX_BODY=2097152

# ---------------------------------------------------------------------------
# Worker 挖掘预算与超时（默认值适合大多数场景，按需调整）
# ---------------------------------------------------------------------------
WORKER_SHELL_TIMEOUT=120
WORKER_SHELL_CAPTURE_MAX_BYTES=524288
WORKER_HTTP_MAX_BYTES=1048576
WORKER_OUTPUT_TRUNCATE=4096
WORKER_LLM_TOOL_OUTPUT_TRUNCATE=4096
WORKER_HISTORY_FULL_TOOL_ROUNDS=4
WORKER_MAX_ROUNDS=90
WORKER_SOFT_ROUNDS=45
WORKER_ROUND_BUDGET_CAP=0
WORKER_SOFT_ROUND_BUDGET_CAP=0
ENTERPRISE_WORKER_ROUND_BUDGET_CAP=0
ENTERPRISE_WORKER_SOFT_ROUND_BUDGET_CAP=0
# 提示词版本：current=省 token 版；legacy=旧版骨架+新工具说明；modern=完整版
WORKER_PROMPT_VERSION=current
WORKER_JS_TOOL_ALWAYS_ON=0
WORKER_WORK_ROOT=/work

WORKER_WALL_TIMEOUT=1800
WORKER_IDLE_TIMEOUT=1800
WORKER_MAX_WALL_TIMEOUT=7200
WORKER_WAIT_POLL_INTERVAL=10
WORKER_CLEANUP_TIMEOUT=15
TARGET_HEARTBEAT_INTERVAL=30

# 容器重启后是否自动恢复之前 running 的任务（0=只起 Web/API，不自动续跑）
AUTOHUNTER_RESTORE_ON_STARTUP=1

# ---------------------------------------------------------------------------
# 同款系统聚类（减少对同产品大量子域的重复 token 消耗）
# ---------------------------------------------------------------------------
TARGET_CLUSTER_DEAD_THRESHOLD=3
TARGET_CLUSTER_PENDING_LIMIT=3

# ---------------------------------------------------------------------------
# 队列派发 / 探活
# ---------------------------------------------------------------------------
QUEUE_DISPATCH_CANDIDATE_LIMIT=120
QUEUE_LIVENESS_TIMEOUT=6
QUEUE_LIVENESS_CONCURRENCY=8
QUEUE_LIVENESS_BATCH_SIZE=24
QUEUE_LIVENESS_CACHE_TTL=300

# ---------------------------------------------------------------------------
# 并发与线程池（collector/worker/reviewer/killsweep/报告助手共用）
# 小内存机器可调小 AUTOHUNTER_AGENT_THREAD_POOL_SIZE。
# ---------------------------------------------------------------------------
AUTOHUNTER_AGENT_THREAD_POOL_SIZE=6
AUTOHUNTER_DEFAULT_THREAD_POOL_SIZE=8
AUTOHUNTER_WATCHDOG_INTERVAL=20
AUTOHUNTER_WATCHDOG_TIMEOUT=5
AUTOHUNTER_WATCHDOG_MAX_FAILURES=3
AUTOHUNTER_WATCHDOG_START_GRACE=20
AUTOHUNTER_WATCHDOG_DIAG_SIGNAL=USR1
AUTOHUNTER_WATCHDOG_DIAG_GRACE=3
AUTOHUNTER_LOOP_LAG_INTERVAL=5
AUTOHUNTER_LOOP_LAG_WARN_SECONDS=10
COLLECTOR_PREFILTER_CONCURRENCY=12
COLLECTOR_SCORE_CONCURRENCY=8

# ---------------------------------------------------------------------------
# 审核 / 通杀 / 报告助手
# ---------------------------------------------------------------------------
KILLSWEEP_DEDUP_SCAN_LIMIT=200
KILLSWEEP_MAX_ROUNDS=24
REVIEW_WALL_TIMEOUT=600
REVIEW_RETRY_BACKOFF=300
KILLSWEEP_WALL_TIMEOUT=3600
REPORT_ASSISTANT_WALL_TIMEOUT=300
REPORT_ASSISTANT_MAX_ROUNDS=10
REPORT_ASSISTANT_HISTORY_TURNS=6
REPORT_ASSISTANT_HISTORY_CHARS=1000
